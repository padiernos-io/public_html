        "predis/predis": "^2.3",
        "sabberworm/php-css-parser": "^8.0"
    },
    "require-dev": {
        "drupal/core-dev": "^11.1",
        "drupal/twig_xdebug": "^1.4",
        "drupal/visual_debugger": "^1.0@alpha",
        "ergebnis/composer-normalize": "^2.48",
        "mglaman/drupal-check": "^1.5",
        "palantirnet/drupal-rector": "^0.20.3",
        "wikimedia/composer-merge-plugin": "^2.1",
        "zaporylie/composer-drupal-optimizations": "^1.2"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        },
        {
            "type": "vcs",
            "url": "https://gitlab.ewdev.ca/yonas.legesse/drupal-recipe-unpack.git"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "chx/drupal-issue-fork": true,
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "drupal/core-recipe-unpack": true,
            "drupal/core-vendor-hardening": true,
            "ergebnis/composer-normalize": true,
            "ewcomposer/unpack": true,
            "mglaman/composer-drupal-lenient": true,
            "oomphinc/composer-installers-extender": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": true,
            "wikimedia/composer-merge-plugin": true,
            "zaporylie/composer-drupal-optimizations": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "composer-exit-on-patch-failure": true,
        "composer-normalize": {
            "indent-size": 4,
            "indent-style": "space"
        },
        "drupal-core-project-message": {
            "include-keys": [
                "homepage",
                "support"
            ],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                   </>",
                "<bg=blue;fg=white>  Congratulations, you’ve installed Drupal CMS!    </>",
                "<bg=blue;fg=white>                                                   </>",
                "",
                "<bg=yellow;fg=black>Next steps</>:",
                "  * Read the user guide: https://www.drupal.org/docs/user_guide/en/index.html",
                "  * Get support: https://drupal.org/support",
                "  * Get involved with the Drupal community: https://drupal.org/getting-involved"
            ]
        },
        "drupal-lenient": {
            "allowed-list": [
                "drupal/big_pipe_sessionless",
                "drupal/social_post_facebook",
                "drupal/social_post_linkedin"
            ]
        },
        "drupal-scaffold": {
            "file-mapping": {
                "[web-root]/.htaccess": false,
                "[web-root]/robots.txt": false
            },
            "locations": {
                "web-root": "web/"
            }
        },
        "enable-patching": true,
        "installer-paths": {
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "recipes/{$name}": [
                "type:drupal-recipe"
            ],
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library",
                "type:bower-asset",
                "type:npm-asset"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "web/modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "web/profiles/custom/{$name}": [
                "type:drupal-custom-profile"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ]
        },
        "installer-types": [
            "npm-asset",
            "bower-asset"
        ],
        "merge-plugin": {
            "include": [
                "web/modules/contrib/webform/composer.libraries.json"
            ]
        },
        "patchLevel": {
            "drupal/contrib-module1": "-p1",
            "drupal/contrib-module2": "-p1",
            "drupal/core": "-p2"
        },
        "patches": {
            "drupal/big_pipe_sessionless": {
                "New major release for Drupal 11 compatibility": "https://www.drupal.org/files/issues/2025-10-02/3428235-big_pipe_sessionless-22.d11.patch"
            },
            "drupal/book_access_code": {
                "Automated Drupal 11 compatibility fixes for book_access_code": "https://www.drupal.org/files/issues/2024-03-15/book_access_code.2.0.1.rector.patch"
            },
            "drupal/layout_paragraphs": {
                "Fix undefined variable warnings in EditComponentForm::orphanedItemsElement()": "https://www.drupal.org/files/issues/2025-12-29/3545135-php84-old-layout-undefined-variable.patch"
            }
        }
    },
    "scripts": {
        "drupal-scaffold": "DrupalComposer\\DrupalScaffold\\Plugin::scaffold",
        "drupal:check": [
            "@drupal:check:modules",
            "@drupal:check:themes"
        ],
        "drupal:check:modules": "vendor/bin/drupal-check web/modules/custom 2>&1 | grep -v 'drupal_root parameter is deprecated' || true",
        "drupal:check:themes": "vendor/bin/drupal-check web/themes/custom 2>&1 | grep -v 'drupal_root parameter is deprecated' || true",
        "drupal:recipe": "drush recipe",
        "drush:aliases": "bash scripts/drush-aliases.sh",
        "drush:aliases:list": "bash scripts/drush-aliases.sh list",
        "drush:aliases:status": "bash scripts/drush-aliases.sh status",
        "drush:aliases:test": "bash scripts/drush-aliases.sh test",
        "fix": [
            "@rector:fix",
            "@normalize:fix"
        ],
        "libraries:clean": "bash scripts/libraries-clean.sh",
        "libraries:install": "bash scripts/libraries-install.sh",
        "libraries:list": "bash scripts/libraries-list.sh",
        "libraries:missing": "bash scripts/libraries-missing.sh",
        "libraries:status": "bash scripts/libraries-status.sh",
        "libraries:update": "bash scripts/libraries-update.sh",
        "normalize:dry": "composer normalize --dry-run",
        "normalize:fix": "composer normalize",
        "project:install": [
            "@composer install --ansi"
        ],
        "project:nuke": [
            "rm -rf composer.lock vendor recipes web/core web/modules/contrib web/themes/contrib",
            "@composer clearcache --ansi"
        ],
        "rector:dry": "vendor/bin/rector process --dry-run",
        "rector:fix": "vendor/bin/rector process"
    }
}

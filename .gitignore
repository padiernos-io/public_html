# =============================================================================
# Drupal CMS Project .gitignore
# =============================================================================

# Composer dependencies
vendor/

# Drupal folders (managed by composer)
web/core/
web/modules/contrib/
web/themes/contrib/
web/profiles/contrib/
web/libraries/

# Drupal sites (keep default settings and services)
!web/sites/default/default.services.yml
!web/sites/default/default.settings.php
web/sites/*

# =============================================================================
# Node.js and Frontend Build Tools
# =============================================================================

# Dependencies
node_modules/

# Package manager files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json

# Uncomment if using alternative package managers
# yarn.lock
# pnpm-lock.yaml

# Build outputs and compiled assets
dist/
build/
*.min.js
*.min.css

# =============================================================================
# Cache and Temporary Files
# =============================================================================

# General cache directories
.cache/
.tmp/
.temp/

# Composer cache (using custom location)
.composer-cache/

# PHPStan cache
phpstan-cache/

# =============================================================================
# Development Environment
# =============================================================================

# OS-specific files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local

# DDEV configuration and runtime files
.ddev/

# IDE and editor files
*.swp
*.swo
*~

# Jetbrains and VSCode directories
.idea/
.vscode/

# mise-en-place configuration files
mise.toml

# historical files
README.old.md

# =============================================================================
# AWStats Web Analytics
# =============================================================================

# AWStats directories
awstats/
awstats-data/
awstats_data/
awstats_sessions/
awstats_temp/

# AWStats configuration and data files
awstats.*.conf
awstats.conf
awstatsdirdata.txt
*.awstats
awstats*.txt
awstats*.html

# AWStats icons (these are in your root, may want to keep them)
awstats-icon/
awstatsicons/

# =============================================================================
# Security and Credentials
# =============================================================================

# SSH keys and certificates
*.pem
*.p12
*.key
id_rsa*
id_ed25519*

# Environment files with secrets
.env.production
.env.staging
.env.aws

# =============================================================================
# Logs and Runtime Files
# =============================================================================

# Application logs
logs/
*.log
error_log

# Runtime files
*.pid
*.seed
*.pid.lock

